# Copia a .env en backend/innova-server

# PostgreSQL (ejemplo alineado con docker-compose.yml de esta carpeta)
DATABASE_URL=postgresql://innova:innova@localhost:5432/innova

PORT=5075

JWT_SECRET=InnovaDevSecretKey_ChangeInProduction_Min32Chars!
JWT_ISSUER=Innova
JWT_AUDIENCE=Innova.Frontend

# Arranque local sugerido:
# 1) docker compose up -d
# 2) npm run db:migrate:dev   (o npm run db:push la primera vez)
# 3) npm run db:seed
# 4) npm run dev

