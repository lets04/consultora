# Variables sugeridas para Render usando Supabase Postgres

NODE_ENV=production

# Runtime Prisma en Render
# Usa el pooler de Supabase. Si es Prisma + autoescalado, este formato ayuda a reducir conexiones.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Migraciones / Prisma CLI
# Usa la conexion directa de Supabase.
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

JWT_SECRET=CAMBIA_ESTA_CLAVE_POR_UNA_SEGURA_DE_32+_CARACTERES
JWT_ISSUER=Innova
JWT_AUDIENCE=Innova.Frontend

# URL publica del frontend desplegado en Vercel
FRONTEND_ORIGIN=https://tu-frontend.vercel.app
